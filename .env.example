PORT=5000
# Direct PostgreSQL connection string — Supabase dashboard → Settings → Database → URI
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
ADMIN_SECRET=
JWT_SECRET=replace-with-a-long-random-secret
GOOGLE_AUTH_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com
EXPO_ACCESS_TOKEN=
NODE_ENV=development
